import { createClient } from "@supabase/supabase-js";

// IMPORTANT: use the SAME Supabase URL and anon key as your main app,
// so the portal writes into the same database your broker app reads.
const url = import.meta.env.VITE_SUPABASE_URL;
const anon = import.meta.env.VITE_SUPABASE_ANON_KEY;

if (!url || !anon) {
  console.warn("Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in Vercel (same values as main app).");
}

export const supabase = createClient(url || "https://placeholder.supabase.co", anon || "placeholder");

// Your broker user id — so portal posts attach to YOUR broker account.
// After deploy, set VITE_BROKER_ID in Vercel to your auth user id (from Supabase → Authentication → Users).
export const BROKER_ID = import.meta.env.VITE_BROKER_ID || null;